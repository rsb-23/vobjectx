[MASTER]
jobs=2
ignore-paths=(?!(vobjectx|tests))/*

[FORMAT]
max-line-length = 130

[REFACTORING]
max-args=8
max-branches = 15
max-locals = 16

[MESSAGES CONTROL]
disable=
    I,
    import-error,
    fixme,
    missing-docstring,
    duplicate-code,
    keyword-arg-before-vararg,
    logging-fstring-interpolation,
